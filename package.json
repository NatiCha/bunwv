{
  "name": "@naticha/bunwv",
  "version": "0.0.4",
  "description": "Headless browser automation CLI for Bun, powered by Bun.WebView",
  "module": "bunwv.ts",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "type": "bun tsc --noEmit"
  },
  "bin": {
    "bunwv": "./bunwv.ts"
  },
  "files": [
    "bunwv.ts",
    "lib/daemon.ts",
    "skills/bunwv/SKILL.md",
    ".claude-plugin/marketplace.json",
    ".claude-plugin/plugin.json"
  ],
  "engines": {
    "bun": ">=1.3.12"
  },
  "keywords": [
    "bun",
    "webview",
    "browser",
    "automation",
    "headless",
    "testing",
    "cli",
    "macos",
    "linux",
    "windows",
    "cross-platform"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.3.11"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
